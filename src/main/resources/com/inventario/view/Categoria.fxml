<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="860.0" spacing="25.0" style="-fx-background-color: #f8fafc; -fx-padding: 25;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.inventario.controller.CategoriaController">
   <children>
      
      <VBox minWidth="280.0" prefWidth="280.0" spacing="12.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-padding: 20;">
         <children>
            <Label text="Nueva Categoría" textFill="#0f172a">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Nombre de la Categoría" textFill="#64748b">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtNombre" prefHeight="35.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Estado" textFill="#64748b">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <ComboBox fx:id="cmbEstado" prefHeight="35.0" prefWidth="240.0" promptText="Activo" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
               </children>
            </VBox>
         </children>
      </VBox>
      
      <VBox spacing="15.0" HBox.hgrow="ALWAYS">
         <children>
            
            <HBox alignment="CENTER_LEFT" prefHeight="40.0">
               <children>
                  <Label text="Gestión de Categorías" textFill="#0f172a">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            
            <TableView fx:id="tblCategorias" prefHeight="410.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn prefWidth="80.0" text="ID" />
                <TableColumn prefWidth="280.0" text="Nombre de Categoría" />
                <TableColumn prefWidth="130.0" text="Estado" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="12.0">
               <children>
                  <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#onAgregar" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #10b981; -fx-background-radius: 6; -fx-cursor: hand;" text="Agregar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnActualizar" mnemonicParsing="false" onAction="#onActualizar" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 6; -fx-cursor: hand;" text="Actualizar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#onEliminar" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #ef4444; -fx-background-radius: 6; -fx-cursor: hand;" text="Eliminar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
         </children>
      </VBox>
      
   </children>
</HBox>