<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.inventario.controller.InventarioController">
   <children>
      
      <VBox layoutX="0.0" layoutY="0.0" prefHeight="600.0" prefWidth="320.0" spacing="15.0" style="-fx-background-color: #1e293b; -fx-padding: 25;">
         <children>
            <Label text="Nuevo Producto" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Nombre del Producto" textFill="#94a3b8">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtNombre" prefHeight="35.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Precio ($)" textFill="#94a3b8">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtPrecio" prefHeight="35.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Stock Disponible" textFill="#94a3b8">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtStock" prefHeight="35.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Estado" textFill="#94a3b8">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <ComboBox fx:id="cmbEstado" prefHeight="35.0" prefWidth="270.0" promptText="Activo" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
               </children>
            </VBox>
         </children>
      </VBox>
      
      <VBox layoutX="345.0" layoutY="25.0" prefHeight="550.0" prefWidth="530.0" spacing="20.0">
         <children>
            
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="530.0">
               <children>
                  <Label text="Panel de Inventario" textFill="#0f172a">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            
            <TableView fx:id="tblProductos" prefHeight="410.0" prefWidth="530.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;">
              <columns>
                <TableColumn prefWidth="180.0" text="Nombre" />
                <TableColumn prefWidth="100.0" text="Stock" />
                <TableColumn prefWidth="110.0" text="Precio" />
                <TableColumn prefWidth="130.0" text="Estado" />
              </columns>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" prefHeight="50.0" prefWidth="530.0" spacing="12.0">
               <children>
                  <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#onAgregar" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #10b981; -fx-background-radius: 6; -fx-cursor: hand;" text="Agregar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnActualizar" mnemonicParsing="false" onAction="#onActualizar" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 6; -fx-cursor: hand;" text="Actualizar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#onEliminar" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #ef4444; -fx-background-radius: 6; -fx-cursor: hand;" text="Eliminar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
         </children>
      </VBox>
      
   </children>
</AnchorPane>
