<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainContainer" prefHeight="600.0" prefWidth="1100.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.inventario.controller.MainLayoutController">
   
    <left>
        <VBox prefHeight="600.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: #1e293b; -fx-padding: 20;">
            <children>
                <Label text="SISTEMA POS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="25.0" top="10.0" />
                    </VBox.margin>
                </Label>
            
                <Button fx:id="btnInventario" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#mostrarInventario" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #334155; -fx-background-radius: 6; -fx-cursor: hand;" text=" 📦  Inventario" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            
                <Button fx:id="btnCategorias" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#mostrarCategorias" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;" text=" 🏷️  Categorías" textFill="#94a3b8">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            
                <Button fx:id="btnMovimientos" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#mostrarMovimientos" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;" text=" 🔄  Movimientos" textFill="#94a3b8">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                
                <Button fx:id="btnProveedores" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#mostrarProveedores" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;" text=" 🚚  Proveedores" textFill="#94a3b8">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                
                <Button fx:id="btnClientes" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#mostrarClientes" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;" text=" 👥  Clientes" textFill="#94a3b8">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </left>
   
    <center>
    </center>
</BorderPane>