<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="860.0" spacing="25.0" style="-fx-background-color: #f8fafc; -fx-padding: 25;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.inventario.controller.MovimientoController">
    <children>
      
        <VBox minWidth="280.0" prefWidth="280.0" spacing="12.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-padding: 20;">
            <children>
                <Label text="Ajustar Stock" textFill="#0f172a">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="5.0" />
                    </VBox.margin>
                </Label>
            
                <VBox spacing="5.0">
                    <children>
                        <Label text="Seleccionar Producto" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <ComboBox fx:id="cmbProducto" prefHeight="35.0" prefWidth="240.0" promptText="Buscar producto..." style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                    </children>
                </VBox>
            
                <VBox spacing="5.0">
                    <children>
                        <Label text="Tipo de Movimiento" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <ComboBox fx:id="cmbTipo" prefHeight="35.0" prefWidth="240.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                    </children>
                </VBox>
            
                <VBox spacing="5.0">
                    <children>
                        <Label text="Cantidad Unidades" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtCantidad" prefHeight="35.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                    </children>
                </VBox>
            
                <VBox spacing="5.0">
                    <children>
                        <Label text="Motivo o Razón" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtMotivo" prefHeight="35.0" promptText="Ej: Compra de proveedor, merma..." style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                    </children>
                </VBox>
            
                <VBox alignment="BOTTOM_CENTER" prefHeight="60.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#onRegistrar" prefHeight="40.0" prefWidth="240.0" style="-fx-background-color: #1e293b; -fx-background-radius: 6; -fx-cursor: hand;" text="Procesar Ajuste" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
      
        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <children>
            
                <HBox alignment="CENTER_LEFT" prefHeight="40.0">
                    <children>
                        <Label text="Kardex / Historial de Movimientos" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            
                <TableView fx:id="tblMovimientos" prefHeight="465.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="180.0" text="Producto" />
                        <TableColumn prefWidth="90.0" text="Tipo" />
                        <TableColumn prefWidth="90.0" text="Cantidad" />
                        <TableColumn prefWidth="200.0" text="Motivo / Razón" />
                        <TableColumn prefWidth="140.0" text="Fecha" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            
            </children>
        </VBox>
      
    </children>
</HBox>