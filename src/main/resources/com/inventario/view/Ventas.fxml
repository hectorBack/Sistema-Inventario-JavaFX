<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="860.0" spacing="25.0" style="-fx-background-color: #f8fafc; -fx-padding: 25;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.inventario.controller.VentasController">
    <children>
      
        <VBox minWidth="300.0" prefWidth="300.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-padding: 20;">
            <children>
                <Label text="Nueva Transacción" textFill="#0f172a">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="5.0" />
                    </VBox.margin>
                </Label>
            
                <VBox spacing="5.0" style="-fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                    <children>
                        <Label text="Seleccionar Cliente" textFill="#64748b">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <ComboBox fx:id="cmbCliente" prefHeight="35.0" prefWidth="260.0" promptText="Buscar o seleccionar cliente" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                    </children>
                </VBox>
            
                <VBox spacing="12.0">
                    <children>
                        <Label text="Detalle del Artículo" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                  
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Producto" textFill="#64748b">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="cmbProducto" prefHeight="35.0" prefWidth="260.0" promptText="Seleccionar artículo" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                            </children>
                        </VBox>
                  
                        <HBox spacing="10.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Cantidad" textFill="#64748b">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtCantidad" prefHeight="35.0" promptText="1" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Precio Unit." textFill="#64748b">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtPrecio" editable="false" prefHeight="35.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;" text="0.00" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                  
                        <Button fx:id="btnAgregarCarrito" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onAgregarAlCarrito" prefHeight="38.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Añadir al Carrito" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
      
        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <children>
            
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label text="Caja de Ventas / POS" textFill="#0f172a">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            
                <TableView fx:id="tblCarrito" prefHeight="300.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            
                <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-padding: 15;">
                    <children>
                  
                        <Button fx:id="btnQuitarItem" mnemonicParsing="false" onAction="#onQuitarItem" prefHeight="38.0" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" text="Quitar Artículo" textFill="#ef4444">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                            <HBox.margin>
                                <Insets right="30.0" />
                            </HBox.margin>
                        </Button>
                  
                        <VBox alignment="CENTER_RIGHT" spacing="2.0">
                            <children>
                                <Label text="TOTAL A PAGAR" textFill="#64748b">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblTotal" text="0.00" textFill="#0f172a">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                            <HBox.margin>
                                <Insets right="10.0" />
                            </HBox.margin>
                        </VBox>
                  
                        <Button fx:id="btnRegistrarVenta" mnemonicParsing="false" onAction="#onRegistrarVentaCompleta" prefHeight="50.0" prefWidth="160.0" style="-fx-background-color: #10b981; -fx-background-radius: 6; -fx-cursor: hand;" text="✔ Procesar Venta" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Button>
                  
                    </children>
                </HBox>
            
            </children>
        </VBox>
      
    </children>
</HBox>